<!DOCTYPE html>
<html lang="{{@root.site.locale}}">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{meta_title}}</title>
    <link rel="stylesheet" href="{{asset "built/screen.css"}}">
    <link rel="stylesheet" href="{{asset "css/font-awesome.min.css"}}">
    
    {{ghost_head}}
</head>

<body class="{{body_class}}{{{block "body_class"}}} is-head-{{#match @root.custom.navigation_layout "Logo on the left"}}left-logo{{else match @root.custom.navigation_layout "Logo in the middle"}}middle-logo{{else}}stacked{{/match}}{{#match @root.custom.title_font "=" "Elegant serif"}} has-serif-title{{/match}}{{#match @root.custom.body_font "=" "Elegant serif"}} has-serif-body{{/match}}">
<div class="gh-site">

    <header id="gh-head" class="gh-head gh-outer">
        <div class="gh-head-inner gh-inner">
            <div class="gh-head-brand">
                <div class="gh-head-brand-wrapper">
                    <a class="gh-head-logo" href="{{@root.site.url}}">
                        {{#if @root.site.logo}}
                            <img src="{{@root.site.logo}}" alt="{{@root.site.title}}">
                        {{else}}
                            {{@root.site.title}}
                        {{/if}}
                    </a>
                </div>
                <button class="gh-search gh-icon-btn" aria-label="Search this site" data-ghost-search>{{> partials/icons/search}}</button>
                <button class="gh-burger"></button>
            </div>

            <nav class="gh-head-menu">
                {{navigation}}
                {{#unless @root.site.members_enabled}}
                    {{#match @root.custom.navigation_layout "Stacked"}}
                        <button class="gh-search gh-icon-btn" aria-label="Search this site" data-ghost-search>{{> partials/icons/search}}</button>
                    {{/match}}
                {{/unless}}
            </nav>

            <div class="gh-head-actions">
                {{#unless @root.site.members_enabled}}
                    {{#match @root.custom.navigation_layout "!=" "Stacked"}}
                        <button class="gh-search gh-icon-btn" aria-label="Search this site" data-ghost-search>{{> partials/icons/search}}</button>
                    {{/match}}
                {{else}}
                    <button class="gh-search gh-icon-btn" aria-label="Search this site" data-ghost-search>{{> partials/icons/search}}</button>
                    <div class="gh-head-members">
                        {{#unless @root.member}}
                            {{#unless @root.site.members_invite_only}}
                                <a class="gh-head-link" href="/#/portal/signin" data-portal="signin">Sign in</a>
                                <a class="gh-head-button" href="/#/portal/signup" data-portal="signup">Subscribe</a>
                            {{else}}
                                <a class="gh-head-button" href="/#/portal/signin" data-portal="signin">Sign in</a>
                            {{/unless}}
                        {{else}}
                            <a class="gh-head-button" href="/account">Account</a>
                        {{/unless}}
                        {{#if @root.site.commerce_enabled}}
                        <div class="cartanza-cart-container">
                            <i class="fs-12 fa fa-shopping-bag" aria-hidden="true" style="color:#666666;font-size: 2em;margin-top: 15px;"></i>
                            <span class="header-icons-noti cartanza-cart-total" style="display: -webkit-box;display: -webkit-flex;display: -moz-box;display: -ms-flexbox;display: flex;justify-content: center;align-items: center;width: 20px;height: 20px;border-radius: 50%;background-color: #111111;color: white;font-size: 12px;position: relative;top: -30px;right: -20px;" >0</span>
                            <div class="cartanza-header-cart">
                                <ul class="header-cart-wrapitem" style="max-height: 270px;overflow: auto;">
                                    <li class="header-cart-item" style="text-align: center;">
                                        <span class="header-cart-item-info" style="color: black;">Empty Cart</span>
                                    </li>
                                </ul>
                                <div class="header-cart-total" style="font-size: 15px;color: #555555;line-height: 1.3;text-align: right;padding-top: 15px;padding-bottom: 25px;padding-right: 3px;">
                                    Subtotal : $0.00
                                </div>
                                <div class="header-cart-buttons" style="    display: -webkit-box;display: -webkit-flex;display: -moz-box;display: -ms-flexbox;display: flex;flex-wrap: wrap;justify-content: space-between;align-items: center;">
                                    <div class="header-cart-wrapbtn" style="width: calc((100% - 10px) / 2);padding: 0px;box-sizing: border-box;">
                                    <!-- Button -->
                                    <a href="/cart" class="flex-c-m size1 bg1 bo-rad-20 hov1 s-text1 trans-0-4" style="border-radius:20px;background-color:#222222;align-items: center;color: white;text-transform:uppercase;padding:12px 20px;">
                                        View Cart
                                    </a>
                                    </div>
                                    <div class="header-cart-wrapbtn" style="width: calc((100% - 10px) / 2);padding: 0px;box-sizing: border-box;">
                                    <!-- Button -->
                                    <a href="/checkout" class="flex-c-m size1 bg1 bo-rad-20 hov1 s-text1 trans-0-4" style="border-radius:20px;background-color:#222222;align-items: center;color: white;text-transform:uppercase;padding:12px 20px;">
                                        Checkout
                                    </a>
                                </div>
                            </div>
                        </div>
                        {{/if}}
                {{/unless}}
            </div>
        </div>
    </header>

    <div class="site-content">
        {{~> body}}
    </div>

    <footer class="gh-foot{{#unless @root.site.secondary_navigation}} no-menu{{/unless}} gh-outer">
        <div class="gh-foot-inner gh-inner">
            <div class="gh-copyright">
                {{@root.site.title}} © {{date format="YYYY"}}
            </div>
            {{#if @root.site.secondary_navigation}}
                <nav class="gh-foot-menu">
                    {{navigation type="secondary"}}
                </nav>
            {{/if}}
            <div class="gh-powered-by">
                <a href="https://cartanza.com/" target="_blank" rel="noopener">Powered by Cartanza</a>
            </div>
        </div>
    </footer>

</div>

{{#is "post, page"}}
    {{> partials/pswp}}
{{/is}}


<style>
    .cartanza-cart-container {
        position: relative;
    }
    .cartanza-header-cart {
        right: 0 !important;
        top: 100% !important;
    }
    @media (max-width: 767px) {
        .cartanza-header-cart {
            display: none !important;
        }
    }
</style>

<script>
    // Select the cart icon and header cart elements
    const cartIcon = document.querySelector('i.fs-12.fa.fa-shopping-bag');
    if(cartIcon) {
        const headerCart = document.querySelector('div.cartanza-header-cart');

        document.addEventListener('click', (event) => {
            if (cartIcon.contains(event.target)) {
                if (window.innerWidth < 768) {
                    window.location.href = '/cart';
                } else {
                    headerCart.classList.toggle('show-header-dropdown');
                }
            } else if (!headerCart.contains(event.target)) {
                headerCart.classList.remove('show-header-dropdown');
            }
        });
        window.onload = function() {
            getCart();
        }
    }
</script>
<script>
    let wasInPortal = window.location.hash.includes('/portal/');

    function checkPortal() {
        const isInPortal = window.location.hash.includes('/portal/');
        if (isInPortal) {
            wasInPortal = true;
        } else if (wasInPortal) {
            wasInPortal = false;
            window.location.reload();
        }
    }

    window.addEventListener('hashchange', () => {
        checkPortal();
    });
    
    // Ghost Portal often uses history.replaceState to close, which doesn't trigger hashchange.
    // We check the hash every 500ms while we believe the portal is open.
    setInterval(checkPortal, 500);

    async function logout(event) {
        event.preventDefault();
        try {
            const response = await fetch('/members/api/session/', {
                method: 'DELETE', // HTTP method
                headers: {
                    'Content-Type': 'application/json' // Specify JSON payload
                },
                body: JSON.stringify({ all: false }) // Convert the data to JSON string
            });

            if (response.ok) {
                console.log('Session logged out successfully');
                window.location.href = '/';
            } else {
                console.error('Failed to logout of session:', response.status, response.statusText);
            }
        } catch (error) {
            console.error('Error:', error);
        }
    }
</script>
<script src="{{asset "built/main.min.js"}}"></script>
{ghost_foot}

</body>
</html>